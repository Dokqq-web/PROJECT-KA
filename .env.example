RUN_CONCURRENCY=2
HTTP_TIMEOUT_MS=15000
HTTP_RETRY_COUNT=2
HTTP_RETRY_BASE_MS=250
MAX_CONNECTOR_ITEMS=500
OUTBOUND_HOST_ALLOWLIST=
ALLOW_PRIVATE_NETWORKS=false
RETENTION_DAYS=30
ARTIFACTS_DIRECTORY=artifacts
UPLOADS_DIRECTORY=data/uploads
MAX_UPLOAD_BYTES=5000000
MAX_REQUEST_BODY_BYTES=8000000
BASELINE_DIRECTORY=baselines
UPDATE_SNAPSHOTS=false
BOOTSTRAP_API_KEY=replace-with-a-long-random-api-key
BOOTSTRAP_NAME=Administrator
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
SECRET_MASTER_KEY=replace-with-32-byte-base64-key
# Optional automatic notifications
NOTIFICATION_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFICATION_NOTIFY_ON=always
